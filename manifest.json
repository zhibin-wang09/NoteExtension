{
  "manifest_version": 3,
  "name": "NoteExtension",
  "version": "1.0",
  "description": "A Note Taking Extension",
  "permissions": [
    "tabs",
    "contextMenus"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "NoteExtension"
  },
  "background": {
    "service_worker": "background.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.ts"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}